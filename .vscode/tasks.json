{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: run FastAPI",
      "type": "shell",
      "command": "uv run uvicorn CEACStatusBot.web.main:app --host 127.0.0.1 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: run Vite",
      "type": "shell",
      "command": "npm run dev -- --host 127.0.0.1",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
